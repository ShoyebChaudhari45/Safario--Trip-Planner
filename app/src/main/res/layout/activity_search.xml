<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".SearchActivity">

    <!-- ═══════════════════════════════════════════════════════
         MAIN SCROLL CONTENT
         ═══════════════════════════════════════════════════════ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ─── IMAGE COLLAGE HEADER ─────────────────────── -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="280dp">

                <!-- 2×2 grid collage background using color placeholders
                     (replace with real ImageViews / Glide once you have photos) -->
                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:columnCount="2"
                    android:rowCount="2">

                    <!-- Top-left: deep blue placeholder -->
                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_columnWeight="1"
                        android:layout_rowWeight="1"
                        android:background="#1C2B5E" />

                    <!-- Top-right: mountain grey placeholder -->
                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_columnWeight="1"
                        android:layout_rowWeight="1"
                        android:background="#B0BEC5" />

                    <!-- Bottom-left: tiger orange placeholder -->
                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_columnWeight="1"
                        android:layout_rowWeight="1"
                        android:background="#FF6B35" />

                    <!-- Bottom-right: forest green placeholder -->
                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_columnWeight="1"
                        android:layout_rowWeight="1"
                        android:background="#2E7D32" />

                </GridLayout>

                <!-- Dark gradient overlay so text is readable -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_header_overlay" />

                <!-- SAFARIO brand text on top of collage -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="SAFARIO"
                    android:textSize="48sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:letterSpacing="0.12"
                    android:fontFamily="sans-serif-black" />

            </FrameLayout>

            <!-- ─── DARK SEARCH CARD (overlaps header) ────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="-36dp"
                android:background="@drawable/bg_search_card_dark"
                android:padding="20dp"
                android:elevation="8dp">

                <!-- FROM row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Location pin icon (white for dark card) -->
                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_location_pin_white"
                        android:padding="6dp"
                        android:contentDescription="From" />

                    <!-- Source input -->
                    <AutoCompleteTextView
                        android:id="@+id/sourceInput"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="Source"
                        android:background="@drawable/bg_input_dark"
                        android:paddingStart="12dp"
                        android:paddingEnd="8dp"
                        android:textSize="16sp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#88FFFFFF"
                        android:completionThreshold="2"
                        android:singleLine="true" />

                    <!-- Swap button — dark circle, right-aligned in FROM row -->
                    <ImageButton
                        android:id="@+id/btnSwap"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_swap"
                        android:background="@drawable/bg_circle_dark"
                        android:contentDescription="Swap"
                        android:padding="10dp" />

                </LinearLayout>

                <!-- Thin divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#33FFFFFF"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="4dp" />

                <!-- TO row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Lightning bolt icon (matches screenshot) -->
                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_lightning"
                        android:padding="6dp"
                        android:contentDescription="To" />

                    <!-- Destination input -->
                    <AutoCompleteTextView
                        android:id="@+id/destinationInput"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="Destination"
                        android:background="@drawable/bg_input_dark"
                        android:paddingStart="12dp"
                        android:paddingEnd="8dp"
                        android:textSize="16sp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#88FFFFFF"
                        android:completionThreshold="2"
                        android:singleLine="true" />

                    <!-- Search button — coral gradient circle -->
                    <ImageButton
                        android:id="@+id/btnFindRoutes"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_search"
                        android:background="@drawable/bg_circle_coral"
                        android:contentDescription="Search"
                        android:padding="10dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Progress bar (hidden until geocoding runs) -->
            <ProgressBar
                android:id="@+id/searchProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:indeterminateTint="@color/primary"
                android:visibility="gone"
                android:layout_marginTop="8dp" />

            <!-- ─── FEATURED TRIPS ────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Featured Trips"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="14dp" />

                <!-- Horizontal scroll of trip cards -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingEnd="4dp">

                        <!-- Kashmir → Kanyakumari -->
                        <androidx.cardview.widget.CardView
                            android:id="@+id/tripKashmirKanyakumari"
                            android:layout_width="160dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="12dp"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="4dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <FrameLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="110dp">

                                    <View
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:background="#546E7A" />

                                    <View
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:background="@drawable/bg_trip_label" />

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="bottom"
                                        android:paddingStart="8dp"
                                        android:paddingBottom="6dp"
                                        android:text="kashmir-kanyakumari"
                                        android:textSize="10sp"
                                        android:textColor="#CCFFFFFF" />
                                </FrameLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:padding="10dp"
                                    android:background="#FFFFFF">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Kashmir to Kanyakumari"
                                        android:textSize="13sp"
                                        android:textStyle="bold"
                                        android:textColor="@color/text_primary" />
                                </LinearLayout>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <!-- Mumbai → Delhi -->
                        <androidx.cardview.widget.CardView
                            android:id="@+id/tripMumbaiDelhi"
                            android:layout_width="160dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="12dp"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="4dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <FrameLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="110dp">

                                    <View
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:background="#8D6E63" />

                                    <View
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:background="@drawable/bg_trip_label" />

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="bottom"
                                        android:paddingStart="8dp"
                                        android:paddingBottom="6dp"
                                        android:text="Mumbai-Delhi"
                                        android:textSize="10sp"
                                        android:textColor="#CCFFFFFF" />
                                </FrameLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:padding="10dp"
                                    android:background="#FFFFFF">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Mumbai to Delhi"
                                        android:textSize="13sp"
                                        android:textStyle="bold"
                                        android:textColor="@color/text_primary" />
                                </LinearLayout>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <!-- Bangalore → Goa -->
                        <androidx.cardview.widget.CardView
                            android:id="@+id/tripBangaloreGoa"
                            android:layout_width="160dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="12dp"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="4dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <FrameLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="110dp">

                                    <View
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:background="#00897B" />

                                    <View
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:background="@drawable/bg_trip_label" />

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="bottom"
                                        android:paddingStart="8dp"
                                        android:paddingBottom="6dp"
                                        android:text="Bangalore-Goa"
                                        android:textSize="10sp"
                                        android:textColor="#CCFFFFFF" />
                                </FrameLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:padding="10dp"
                                    android:background="#FFFFFF">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Bangalore to Goa"
                                        android:textSize="13sp"
                                        android:textStyle="bold"
                                        android:textColor="@color/text_primary" />
                                </LinearLayout>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>

            <!-- ─── HOW IT WORKS ──────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="24dp"
                android:paddingBottom="90dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="How it Works"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="14dp" />

                <!-- Step 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_search"
                        android:background="@drawable/bg_circle_icon"
                        android:padding="8dp"
                        android:contentDescription="Search" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Find flights, trains, buses, and more!"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginStart="14dp" />
                </LinearLayout>

                <!-- Step 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_hotel"
                        android:background="@drawable/bg_circle_icon"
                        android:padding="8dp"
                        android:contentDescription="Hotel" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Compare and book the best hotels."
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginStart="14dp" />
                </LinearLayout>

                <!-- Step 3 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_place"
                        android:background="@drawable/bg_circle_icon"
                        android:padding="8dp"
                        android:contentDescription="Explore" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Explore nearby attractions at your destination."
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginStart="14dp" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ═══════════════════════════════════════════════════════
         BOTTOM NAVIGATION BAR (pinned)
         ═══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:background="@drawable/bg_bottom_nav"
        android:gravity="center_vertical"
        android:elevation="16dp">

        <!-- Home tab (active) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_nav_active"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_home"
                    android:contentDescription="Home" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Home"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#FF6B35"
                    android:layout_marginStart="6dp" />
            </LinearLayout>

        </LinearLayout>

        <!-- Profile tab (inactive) -->
        <LinearLayout
            android:id="@+id/tabProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_profile"
                android:contentDescription="Profile" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
