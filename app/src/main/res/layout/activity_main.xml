<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash"
    tools:context=".MainActivity">

    <!-- Large faint circle — top right decorative glow -->
    <View
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:background="@drawable/bg_glow_circle"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="-80dp"
        android:layout_marginEnd="-80dp"
        tools:ignore="MissingConstraints" />

    <!-- Small faint circle — bottom left decorative glow -->
    <View
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:background="@drawable/bg_glow_circle_sm"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="-60dp"
        android:layout_marginStart="-60dp"
        tools:ignore="MissingConstraints" />

    <!-- Logo icon -->
    <ImageView
        android:id="@+id/splashIcon"
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:src="@drawable/ic_splash_plane"
        android:contentDescription="Safario"
        app:layout_constraintBottom_toTopOf="@+id/appName"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="20dp" />

    <!-- App name -->
    <TextView
        android:id="@+id/appName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Safario"
        android:textSize="46sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:letterSpacing="0.04"
        app:layout_constraintBottom_toTopOf="@+id/tagline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="6dp" />

    <!-- Tagline -->
    <TextView
        android:id="@+id/tagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your Journey, Perfectly Planned."
        android:textSize="15sp"
        android:textColor="#CCF5F0FF"
        android:letterSpacing="0.04"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp" />

    <!-- Coral accent dot row -->
    <LinearLayout
        android:id="@+id/dotRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@+id/tagline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="18dp">

        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/bg_dot_coral"
            android:layout_marginEnd="5dp" />
        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/bg_dot_white"
            android:layout_marginEnd="5dp" />
        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/bg_dot_white" />

    </LinearLayout>

    <!-- Loading spinner -->
    <ProgressBar
        android:id="@+id/splashProgress"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:indeterminateTint="#FFCA28"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="72dp" />

    <!-- Version label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0"
        android:textSize="11sp"
        android:textColor="#55FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="22dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
