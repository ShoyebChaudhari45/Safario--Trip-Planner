<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2F2F2"
    tools:context=".NearbyPlacesActivity">

    <!-- Title bar -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nearby Tourist Spots"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        android:gravity="center"
        android:paddingTop="20dp"
        android:paddingBottom="16dp"
        android:background="#F2F2F2" />

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/nearbyProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="40dp"
        android:indeterminateTint="@color/primary"
        android:visibility="gone" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/nearbyEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No tourist spots found nearby."
        android:textSize="14sp"
        android:textColor="#888888"
        android:gravity="center"
        android:layout_marginTop="60dp"
        android:visibility="gone" />

    <!-- RecyclerView list matching screenshot style -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/nearbyPlacesList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="8dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false" />

</LinearLayout>
