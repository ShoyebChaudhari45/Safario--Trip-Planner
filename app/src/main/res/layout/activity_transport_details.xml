<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".TransportDetailsActivity">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient_primary"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="56dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Train Search"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enter station codes to find trains"
            android:textSize="15sp"
            android:textColor="#B3FFFFFF"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="148dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="24dp"
            android:paddingTop="8dp">

            <!-- Station Code Input Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-40dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="From Station Code"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/etFromCode"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="e.g. NDLS"
                        android:background="@drawable/bg_input_field"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:inputType="textCapCharacters"
                        android:layout_marginBottom="14dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="To Station Code"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/etToCode"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="e.g. CSTM"
                        android:background="@drawable/bg_input_field"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:inputType="textCapCharacters"
                        android:layout_marginBottom="16dp" />

                    <Button
                        android:id="@+id/btnSearch"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="Search Trains"
                        android:textAllCaps="false"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:background="@drawable/bg_button_primary" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Common Station Codes Reference Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Common Station Codes"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="14dp" />

                    <!-- North India -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NORTH INDIA"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="NDLS" android:textStyle="bold" android:textColor="@color/primary" android:textSize="13sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="New Delhi" android:textColor="@color/text_primary" android:textSize="13sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="DLI" android:textStyle="bold" android:textColor="@color/primary" android:textSize="13sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Old Delhi" android:textColor="@color/text_primary" android:textSize="13sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="NZM" android:textStyle="bold" android:textColor="@color/primary" android:textSize="13sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Hazrat Nizamuddin, Delhi" android:textColor="@color/text_primary" android:textSize="13sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="AGC" android:textStyle="bold" android:textColor="@color/primary" android:textSize="13sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Agra Cantt" android:textColor="@color/text_primary" android:textSize="13sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="LKO" android:textStyle="bold" android:textColor="@color/primary" android:textSize="13sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Lucknow" android:textColor="@color/text_primary" android:textSize="13sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="BSB" android:textStyle="bold" android:textColor="@color/primary" android:textSize="13sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Varanasi" android:textColor="@color/text_primary" android:textSize="13sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="PRYJ" android:textStyle="bold" android:textColor="@color/primary" android:textSize="13sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Prayagraj (Allahabad)" android:textColor="@color/text_primary" android:textSize="13sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="14dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="JP" android:textStyle="bold" android:textColor="@color/primary" android:textSize="13sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Jaipur" android:textColor="@color/text_primary" android:textSize="13sp"/>
                    </LinearLayout>

                    <!-- West India -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="WEST INDIA"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="CSTM" android:textStyle="bold" android:textColor="@color/primary" android:textSize="13sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Mumbai CST" android:textColor="@color/text_primary" android:textSize="13sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="BCT" android:textStyle="bold" android:textColor="@color/primary" android:textSize="13sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Mumbai Central" android:textColor="@color/text_primary" android:textSize="13sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="ADI" android:textStyle="bold" android:textColor="@color/primary" android:textSize="13sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Ahmedabad" android:textColor="@color/text_primary" android:textSize="13sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="ST" android:textStyle="bold" android:textColor="@color/primary" android:textSize="13sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Surat" android:textColor="@color/text_primary" android:textSize="13sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="14dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="PUNE" android:textStyle="bold" android:textColor="@color/primary" android:textSize="13sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Pune" android:textColor="@color/text_primary" android:textSize="13sp"/>
                    </LinearLayout>

                    <!-- South India -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SOUTH INDIA"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="MAS" android:textStyle="bold" android:textColor="@color/primary" android:textSize="13sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Chennai Central" android:textColor="@color/text_primary" android:textSize="13sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="SBC" android:textStyle="bold" android:textColor="@color/primary" android:textSize="13sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Bangalore (KSR)" android:textColor="@color/text_primary" android:textSize="13sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="HYB" android:textStyle="bold" android:textColor="@color/primary" android:textSize="13sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Hyderabad Deccan" android:textColor="@color/text_primary" android:textSize="13sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="SC" android:textStyle="bold" android:textColor="@color/primary" android:textSize="13sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Secunderabad" android:textColor="@color/text_primary" android:textSize="13sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="ERS" android:textStyle="bold" android:textColor="@color/primary" android:textSize="13sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Ernakulam (Kochi)" android:textColor="@color/text_primary" android:textSize="13sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="14dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="TVC" android:textStyle="bold" android:textColor="@color/primary" android:textSize="13sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Thiruvananthapuram" android:textColor="@color/text_primary" android:textSize="13sp"/>
                    </LinearLayout>

                    <!-- East India -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EAST INDIA"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="HWH" android:textStyle="bold" android:textColor="@color/primary" android:textSize="13sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Howrah (Kolkata)" android:textColor="@color/text_primary" android:textSize="13sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="SDAH" android:textStyle="bold" android:textColor="@color/primary" android:textSize="13sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Sealdah (Kolkata)" android:textColor="@color/text_primary" android:textSize="13sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="PNBE" android:textStyle="bold" android:textColor="@color/primary" android:textSize="13sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Patna" android:textColor="@color/text_primary" android:textSize="13sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="BBS" android:textStyle="bold" android:textColor="@color/primary" android:textSize="13sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Bhubaneswar" android:textColor="@color/text_primary" android:textSize="13sp"/>
                    </LinearLayout>

                    <!-- Central India -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CENTRAL INDIA"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="8dp"
                        android:layout_marginTop="8dp" />

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="NGP" android:textStyle="bold" android:textColor="@color/primary" android:textSize="13sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Nagpur" android:textColor="@color/text_primary" android:textSize="13sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="INDB" android:textStyle="bold" android:textColor="@color/primary" android:textSize="13sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Indore" android:textColor="@color/text_primary" android:textSize="13sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="BPL" android:textStyle="bold" android:textColor="@color/primary" android:textSize="13sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Bhopal" android:textColor="@color/text_primary" android:textSize="13sp"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Results Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_train"
                            android:contentDescription="Train"
                            android:background="@drawable/bg_circle_icon"
                            android:padding="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Results"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginStart="12dp" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/trainDetails"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Enter station codes above and tap Search."
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:lineSpacingExtra="6dp"
                        android:padding="4dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
